<UserControl x:Class="JackAll.App.FileHandlers.Xbg.XbgFileHandler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TextBlock x:Name="StatusText" DockPanel.Dock="Top" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />

        <StackPanel x:Name="Toolbar" DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,12,0,0" Visibility="Collapsed">
            <TextBlock Text="LOD:" VerticalAlignment="Center" Margin="0,0,6,0" />
            <ComboBox x:Name="LodCombo" Width="90" SelectionChanged="LodCombo_SelectionChanged" />
            <Button x:Name="ResetViewButton" Content="Reset view" Margin="16,0,0,0" Padding="8,2" Click="ResetViewButton_Click" />
        </StackPanel>

        <!-- Fills whatever space DockPanel has left. -->
        <Border Margin="0,16,0,0" Background="#20242C" BorderBrush="#DDD" BorderThickness="1">
            <Viewport3D x:Name="Viewport" ClipToBounds="True"
                        MouseDown="Viewport_MouseDown" MouseUp="Viewport_MouseUp"
                        MouseMove="Viewport_MouseMove" MouseWheel="Viewport_MouseWheel">
                <Viewport3D.Camera>
                    <PerspectiveCamera x:Name="Camera" FieldOfView="45" />
                </Viewport3D.Camera>
            </Viewport3D>
        </Border>
    </DockPanel>
</UserControl>
