<UserControl x:Class="JackAll.App.FileHandlers.Text.TextFileHandler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:fh="clr-namespace:JackAll.App.FileHandlers.Text">
    <UserControl.Resources>
        <fh:ExtensionToHighlightingConverter x:Key="ExtensionToHighlighting" />
    </UserControl.Resources>
    <DockPanel>
        <TextBlock x:Name="DiffBanner" DockPanel.Dock="Top" Visibility="Collapsed" TextWrapping="Wrap"
                   Background="#FFF8E1" Foreground="#7A5B00" Padding="6,4" FontSize="11" Margin="0,0,0,4"
                   Text="Showing only the changed lines plus a little context - Export… gets the whole file." />
        <avalonEdit:TextEditor x:Name="Editor" IsReadOnly="True" ShowLineNumbers="True" WordWrap="False"
                                FontFamily="Consolas" FontSize="12" Background="#FAFAFA"
                                SyntaxHighlighting="{Binding Extension, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource ExtensionToHighlighting}}" />
    </DockPanel>
</UserControl>
