<UserControl x:Class="JackAll.App.FileHandlers.Sbao.SbaoFileHandler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TextBlock x:Name="StatusText" DockPanel.Dock="Top" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,16,0,0">
            <TextBlock Text="Export as:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox x:Name="ExportFormatCombo" Width="220" SelectedIndex="0" VerticalAlignment="Center">
                <ComboBoxItem Content="Ogg Vorbis (original)" />
                <ComboBoxItem Content="MP3 (good quality, VBR)" />
            </ComboBox>
            <Button x:Name="ExportButton" Content="Export…" Click="Export_Click"
                    Padding="8,6" Margin="8,0,0,0" IsEnabled="False" />
            <Button x:Name="ImportButton" Content="Import…" Click="Import_Click"
                    Padding="8,6" Margin="16,0,0,0" />
        </StackPanel>

        <Border DockPanel.Dock="Top" Margin="0,16,0,0" Background="#ECECEC" BorderBrush="#DDD" BorderThickness="1" Padding="12">
            <StackPanel>
                <TextBlock Text="Preview" FontWeight="Bold" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="PlayButton" Content="▶ Play" Click="Play_Click" Padding="8,6" Margin="0,0,8,0" IsEnabled="False" />
                    <Button x:Name="PauseButton" Content="❚❚ Pause" Click="Pause_Click" Padding="8,6" Margin="0,0,8,0" IsEnabled="False" />
                    <Button x:Name="StopButton" Content="■ Stop" Click="Stop_Click" Padding="8,6" IsEnabled="False" />
                </StackPanel>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SeekBar" Grid.Column="0" Minimum="0" Maximum="1"
                            IsMoveToPointEnabled="True" IsEnabled="False"
                            PreviewMouseDown="SeekBar_PreviewMouseDown" PreviewMouseUp="SeekBar_PreviewMouseUp"
                            ValueChanged="SeekBar_ValueChanged" VerticalAlignment="Center" />
                    <TextBlock x:Name="TimeText" Grid.Column="1" Margin="8,0,0,0" FontFamily="Consolas" FontSize="12"
                               VerticalAlignment="Center" Text="0:00 / 0:00" />
                </Grid>
                <MediaElement x:Name="Player" Visibility="Collapsed"
                              LoadedBehavior="Manual" UnloadedBehavior="Manual"
                              MediaOpened="Player_MediaOpened" MediaEnded="Player_MediaEnded" />
            </StackPanel>
        </Border>
    </DockPanel>
</UserControl>
