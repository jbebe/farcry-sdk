<UserControl x:Class="JackAll.App.FileHandlers.Rml.RmlFileHandler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:text="clr-namespace:JackAll.App.FileHandlers.Text">
    <DockPanel Margin="16">
        <TextBlock x:Name="StatusText" DockPanel.Dock="Top" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,16,0,0">
            <Button x:Name="ExportButton" Content="Export XML…" Click="Export_Click"
                    Padding="8,6" Margin="0,0,8,0" IsEnabled="False" />
            <Button x:Name="ImportButton" Content="Import XML…" Click="Import_Click"
                    Padding="8,6" />
        </StackPanel>

        <!-- Unlike .fcb, .rml never splits into external sub-files - this is the whole decoded tree. -->
        <Border Margin="0,16,0,0" Background="#FAFAFA" BorderBrush="#DDD" BorderThickness="1">
            <text:TextFileHandler x:Name="Preview" Extension="xml" />
        </Border>
    </DockPanel>
</UserControl>
