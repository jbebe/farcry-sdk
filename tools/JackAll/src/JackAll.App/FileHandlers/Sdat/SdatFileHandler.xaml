<UserControl x:Class="JackAll.App.FileHandlers.Sdat.SdatFileHandler"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="16">
        <TextBlock x:Name="StatusText" DockPanel.Dock="Top" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,16,0,0">
            <Button x:Name="ExportButton" Content="Export as PNG…" Click="Export_Click"
                    Padding="8,6" IsEnabled="False" />
        </StackPanel>

        <!-- Fills whatever space DockPanel has left; Stretch=Uniform keeps the heightmap square, aspect intact. -->
        <Border Margin="0,16,0,0" Background="#ECECEC" BorderBrush="#DDD" BorderThickness="1">
            <Image x:Name="Preview" Stretch="Uniform" RenderOptions.BitmapScalingMode="NearestNeighbor" />
        </Border>
    </DockPanel>
</UserControl>
