<UserControl x:Class="JackAll.App.XmlEditor.RmlTextEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
             BorderBrush="#ABADB3" BorderThickness="1" Background="White">
    <!-- A decoded .rml document is nested XML, not a one-line value, so the Rml field in the property
         grid (see FcbFieldFormat, XmlEditorTabView's ScalarField template) gets this instead of the
         plain single-line TextBox every other scalar type uses. Height isn't set here - the
         code-behind grows it with the document up to a capped number of lines (see UpdateHeight),
         past which the rest scrolls via the editor's own ScrollViewer instead of growing further. -->
    <avalonEdit:TextEditor x:Name="Editor" FontFamily="Consolas" FontSize="12"
                            ShowLineNumbers="False" WordWrap="False"
                            HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                            BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Background="{Binding Background, RelativeSource={RelativeSource AncestorType=UserControl}}" />
</UserControl>
